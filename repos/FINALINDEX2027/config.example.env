AZ_STORAGE_ACCOUNT="menageriesa36965"
AZ_RESOURCE_GROUP="menagerie-rg"

AZ_FILES_SHARE="local-mirror"
LOCAL_ROOT="$HOME/AzureFiles/local-mirror"

# Share-level SAS token for Azure Files share, WITHOUT leading '?' 
# Must include at least: read, write, delete, list.
AZCOPY_FILES_SAS=""

# Optional: guarded Blob mirroring (container-level SAS tokens), WITHOUT leading '?' 
AZ_BLOB_CONTAINER=""
AZCOPY_BLOB_SAS=""

# Default sync behavior
DELETE_DESTINATION="prompt"  # true | prompt | false